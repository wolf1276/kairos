# KAIROS ENVIRONMENT VARIABLES

# Stellar Network Settings
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Deployed Contract IDs (Phase 1)
DELEGATION_MANAGER_CONTRACT_ID=CDZ3P5DWT3ZCOYWROHAA7PQPF53MBIZTFFYKCRQJIAD74TAECMFNCYEN
POLICY_CONTRACT_ID=CBD3N3R6GFZAFCBAALQCX32BUTUIWVJRKZCQS7HVXHMQZL32VTXD5NHS
CUSTOM_ACCOUNT_CONTRACT_ID=CALOHOUNJEUFMF5R7GIMVWQIN32I7OCNFRVYKFVFAV3F35GRZEXCGI57
CUSTOM_ACCOUNT_WASM_HASH=520c9df34b7dfa1b15309c489f40e6fad1012f7b95795b9888bdad52257b1a3b
REGISTRY_CONTRACT_ID=

# Funder Keypair (must be funded with testnet XLM for on-chain delegation operations)
# Generate with: stellar keys generate funder --network testnet
# Fund with: curl "https://friendbot.stellar.org?addr=G..."
FUNDER_SECRET_KEY=

# AI & Decision Layer
# Hugging Face API Key — powers Intent mode's natural-language trade parsing
# (apps/web/lib/decision/hfIntentParser.ts).
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Gemini API Key — powers Agent Creation's natural-language intent parsing
# (backend/src/intentParser.ts).
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Database Settings
# URL for persistence layer (e.g. Turso / libSQL / local Postgres / local SQLite)
DATABASE_URL=file:local.db

# Turnkey (MPC key custody for agent private keys — see backend/ and packages/mcp-agent)
# Every agent's Ed25519 key is created and held inside this Turnkey organization; the API
# key below only authenticates requests to Turnkey, it cannot reconstruct any agent's key.
# Put the exported API key JSON (never committed — see .gitignore) at secrets/kairos-api-turnkey.json,
# or set TURNKEY_API_PUBLIC_KEY / TURNKEY_API_PRIVATE_KEY directly instead of this file.
TURNKEY_ORGANIZATION_ID=
TURNKEY_CREDENTIALS_FILE=./secrets/kairos-api-turnkey.json

# Frontend (apps/web) — public, inlined into the client bundle at build time
# Render backend's public URL, e.g. https://kairos-agent-backend.onrender.com
NEXT_PUBLIC_AGENTS_BACKEND_URL=

# Required for Mainnet USDC balance/quote functionality (apps/web/app/lib/stellar.ts's
# usdcIssuerForNetwork) — throws at request time on mainnet if left unset. Not needed for
# testnet. Never hardcode a value here.
NEXT_PUBLIC_MAINNET_USDC_ISSUER=
