{
  "name": "kairos-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "app",
    "comming-soon"
  ],
  "scripts": {
    "build": "pnpm --filter @wolf1276/kairos-sdk build",
    "test": "pnpm --filter @wolf1276/kairos-sdk test",
    "demo": "npx tsx scripts/demo-e2e.ts",
    "integration": "npx tsx scripts/test-integration.ts",
    "deploy": "npx tsx scripts/deploy-testnet.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@wolf1276/kairos-sdk": "workspace:^",
    "axios": "^1.18.1",
    "technicalindicators": "^3.1.0"
  }
}
