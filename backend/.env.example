STELLAR_NETWORK=testnet
DELEGATION_MANAGER_CONTRACT_ID=
POLICY_CONTRACT_ID=
CUSTOM_ACCOUNT_CONTRACT_ID=

# Turnkey (MPC key custody) — every new agent gets its own Ed25519 key created inside this
# Turnkey organization; the API key below only authenticates requests to Turnkey and cannot
# reconstruct any agent's key. Point TURNKEY_CREDENTIALS_FILE at the exported API key JSON
# (never committed — see repo root .gitignore), or set TURNKEY_API_PUBLIC_KEY /
# TURNKEY_API_PRIVATE_KEY directly instead of a file.
TURNKEY_ORGANIZATION_ID=
TURNKEY_CREDENTIALS_FILE=../secrets/kairos-api-turnkey.json

# 64-char hex (32 bytes) — generate with: openssl rand -hex 32
# Only used to decrypt agents created before Turnkey integration; new agents are Turnkey-backed
# and don't need this. Keep it set if any pre-existing agent rows still have encrypted_secret.
AGENT_MASTER_KEY=

PORT=4001
AGENTS_DB_PATH=./data/agents.db
ALLOWED_ORIGIN=http://localhost:3000
SCHEDULER_INTERVAL_MS=30000

# Signs session tokens issued after Freighter wallet-signature login — generate with:
# openssl rand -hex 32
AUTH_JWT_SECRET=

# Reasoning Engine (LLM Integration) — provider is config-driven, no code change needed to swap.
# Only the API key for the selected REASONING_PROVIDER is required. Default provider is
# `openrouter`, which requires only OPENROUTER_API_KEY (or OPENROUTER) — no OpenAI/Anthropic/
# DeepSeek/Gemini key needed. Leave REASONING_MODEL unset (or "auto") to always resolve a free
# OpenRouter model dynamically, with automatic fallback across free models if one is unavailable
# — it never routes to a paid model. See docs/architecture/REASONING_ENGINE.md for the fallback
# order and free-model registry.
REASONING_PROVIDER=openrouter
REASONING_MODEL=
REASONING_TEMPERATURE=0.2
REASONING_MAX_TOKENS=2000
REASONING_TIMEOUT_MS=30000
REASONING_MAX_RETRIES=2
REASONING_STRUCTURED_OUTPUT=true
OPENROUTER_API_KEY=

# Only needed if REASONING_PROVIDER is switched to one of these instead of openrouter.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# NVIDIA's hosted inference API (integrate.api.nvidia.com) — also OpenAI-compatible. Set
# REASONING_PROVIDER=nvidia and REASONING_MODEL to an NVIDIA-hosted model id (e.g. z-ai/glm-5.2)
# to use it instead of openrouter.
NVIDIA_API_KEY=

# Ollama running on a separate machine, tunneled via Cloudflare Tunnel + a local auth-proxy
# (Ollama has no auth of its own — the proxy enforces OLLAMA_API_KEY as a shared secret, not a
# real Ollama key). Set REASONING_PROVIDER=ollama, OLLAMA_BASE_URL to the tunnel's public URL
# + /v1, OLLAMA_API_KEY to the proxy's shared secret, and REASONING_MODEL to a model pulled on
# that machine (e.g. qwen3.5:9b).
OLLAMA_BASE_URL=
OLLAMA_API_KEY=

# Blend lending pool (protocolAdapters/blend) — real testnet deployment, verified live from the
# official https://github.com/blend-capital/blend-utils/blob/main/testnet.contracts.json (fetched
# 2026-07-07). `poolFactoryV2`/`backstopV2` are listed for completeness but not used directly by
# this adapter (single-pool integration, no factory discovery); `BLEND_POOL_CONTRACT_ID_TESTNET`
# is the actual `TestnetV2` lending pool this adapter's `submit()` calls invoke.
BLEND_POOL_CONTRACT_ID_TESTNET=CCEBVDYM32YNYCVNRXQKDFFPISJJCV557CDZEIRBEE4NCV4KHPQ44HGF
BLEND_POOL_CONTRACT_ID_MAINNET=
# Mainnet requires a real deployed pool id from https://docs.blend.capital/mainnet-deployments —
# left blank deliberately; this adapter fails closed (throws) rather than guessing one.
BLEND_SOROBAN_RPC_URL=
BLEND_MIN_HEALTH_FACTOR=1.2
