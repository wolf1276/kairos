{
  "name": "@wolf1276/kairos-sdk",
  "version": "1.0.2",
  "description": "Official TypeScript SDK for the Kairos Soroban Delegation Framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@stellar/stellar-sdk": "^14.6.1"
  },
  "devDependencies": {
    "@stellar/stellar-sdk": "^14.6.1",
    "pathe": "^2.0.3",
    "tsup": "^8.0.2",
    "typescript": "^5.0.0",
    "vitest": "^1.3.1"
  },
  "keywords": [
    "stellar",
    "soroban",
    "delegation",
    "sdk",
    "framework",
    "smart-wallet",
    "account-abstraction",
    "typescript"
  ],
  "author": "Kairos Team",
  "license": "MIT",
  "homepage": "https://github.com/wolf1276/kairos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wolf1276/kairos.git"
  },
  "bugs": {
    "url": "https://github.com/wolf1276/kairos/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
